{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/article", "destination": "/api/article-page" }
  ],
  "functions": {
    "api/article-page.js": {
      "includeFiles": "article.html"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
